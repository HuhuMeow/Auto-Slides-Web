# Default provider used by new Web jobs
LLM_DEFAULT_PROVIDER=deepseek

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat
DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner

# OpenRouter (optional)
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o
OPENROUTER_MODELS=openai/gpt-4o,openai/gpt-4.1

# Runtime paths default to .runtime/ and normally need no override
# AUTOSLIDES_RUNTIME_DIR=/absolute/path/to/runtime
# AUTOSLIDES_DATA_DIR=/absolute/path/to/data
# AUTOSLIDES_MARKER_MODEL_DIR=/absolute/path/to/models
AUTOSLIDES_MAX_WORKERS=2

# Replace default development credentials in shared deployments
AUTOSLIDES_ADMIN_USERNAME=admin
AUTOSLIDES_ADMIN_PASSWORD=change-me
AUTOSLIDES_USER_USERNAME=user1
AUTOSLIDES_USER_PASSWORD=change-me
